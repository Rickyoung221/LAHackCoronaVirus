# Copy to .env.local (do not commit .env.local).
# Vercel: add GOOGLE_MAP_PLATFORM in Project → Settings → Environment Variables.
GOOGLE_MAP_PLATFORM=

# Advanced markers use mapId in code (default DEMO_MAP_ID). For production, create a Map ID in
# Google Cloud → Map Management and replace MAP_ID in js/homepage-map.js / js/index-app.js (or factor to one shared file).
