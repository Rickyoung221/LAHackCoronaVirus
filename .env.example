# Copy to .env.local (do not commit .env.local).
# Vercel: add GOOGLE_MAP_PLATFORM in Project → Settings → Environment Variables.
GOOGLE_MAP_PLATFORM=

# Same key must have these APIs enabled (APIs & Services → Library) + billing:
#   Maps JavaScript API, Places API (New) — required for homepage address suggestions,
#   Geocoding API (Go button / free-text search),
#   Routes API — driving-distance table uses RouteMatrix (replaces legacy Distance Matrix for that flow).

# Advanced markers need mapId: see MAP_ID in js/homepage-map.js (default DEMO_MAP_ID). For production,
# create a Map ID in Google Cloud → Map Management and set MAP_ID there (and in other HTML demos as needed).
